{
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "bun run --filter '@pivanov/claude-wire' build",
    "test": "bun run --filter '@pivanov/claude-wire' test",
    "typecheck": "bun run --filter '@pivanov/claude-wire' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "docs:dev": "bun run --filter claude-wire-docs dev",
    "docs:build": "bun run --filter claude-wire-docs build",
    "examples": "bun --silent run apps/examples/cli.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "publish": "cd packages/claude-wire && npm publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0"
  }
}
